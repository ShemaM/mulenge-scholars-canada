{
  "functions": {
    "app/[[]locale[]]/(frontend)/**/*.tsx": {
      "maxDuration": 30
    },
    "app/(payload)/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/admin/(.*)",
      "dest": "/app/(payload)/admin/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=59"
        }
      ]
    }
  ]
}
